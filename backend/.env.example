# Server
NODE_ENV=development
APP_ENV=staging
PORT=4002
API_PREFIX=/api

# Frontend origin allowed by CORS.
# Local Vite default:
CORS_ORIGIN=http://localhost:5173

# Neon/PostgreSQL.
# Use the Neon development branch connection string for local backend work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=40mb

# File storage
# Use local for development. Use google_drive in production after sharing the root
# folder with the service account.
STORAGE_PROVIDER=local
MAX_UPLOAD_SIZE_MB=10
MAX_PUNCH_PHOTO_SIZE_MB=2
CLOCK_ATTEMPT_PROCESSING_TTL_MS=60000
CLOCK_ATTEMPT_RETENTION_DAYS=30
CLOCK_ATTEMPT_MAINTENANCE_INTERVAL_MS=60000
# Revisa el día operativo anterior a las 04:00 de Argentina, después del último turno nocturno.
ATTENDANCE_INACTIVITY_CHECK_HOUR=4
ATTENDANCE_INACTIVITY_CHECK_MINUTE=0

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=gestion-personal

GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_PROJECT_ID=
