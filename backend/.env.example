# Server
NODE_ENV=development
PORT=4002
API_PREFIX=/api

# Frontend origin allowed by CORS.
# Local Vite default:
CORS_ORIGIN=http://localhost:5173

# Neon/PostgreSQL.
# Use the Neon development branch connection string for local backend work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=40mb

# File storage
# Keep local while storage credentials are not configured.
# Later, switch to cloudinary and fill Cloudinary credentials.
STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=gestion-personal
