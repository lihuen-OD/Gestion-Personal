generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  NIVEL_1_RRHH
  NIVEL_2_SUPERVISION
  NIVEL_3_CARGA_HORARIA
}

enum RecordStatus {
  ACTIVO
  INACTIVO
}

enum EmployeeStatus {
  ACTIVO
  INACTIVO
}

enum LaborMovementType {
  ALTA
  BAJA
}

enum NoveltyTypeKind {
  AUSENCIA
  LICENCIA
  HORARIA
  ACCIDENTE
  VACACIONES
  SANCION
  OTRO
}

enum NoveltyTypeOrigin {
  INTERNA
  FINNEGANS
  MIXTA
}

enum NoveltyTimeImpact {
  NO_AFECTA_HORAS
  REGISTRA_HORAS_NO_TRABAJADAS
  BLOQUEA_CARGA_DIA
}

enum ApprovalStatus {
  BORRADOR
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
  DEVUELTO
  CERRADO
}

enum WorkShiftStatus {
  ABIERTO
  PROCESADO
  OBSERVADO
  ANULADO
  FALTA_SALIDA
  FALTA_INGRESO
  INVALIDO
  REVISADO
  CERRADO_MANUAL
}

enum WorkShiftSource {
  ADMIN
  PORTAL_DNI
  PUBLIC_CLOCK_PHOTO
  KIOSK
  BIOTIME
  FACIAL
}

enum AttendancePunchType {
  INGRESO
  SALIDA
}

enum AttendancePunchStatus {
  VALIDA
  OBSERVADA
  RECHAZADA
}

enum AttendanceReviewStatus {
  PENDIENTE
  RESUELTA
  DESCARTADA
}

enum FaceValidationStatus {
  VALID
  NO_FACE
  MULTIPLE_FACES
  LOW_LIGHT
  FACE_TOO_SMALL
  CAMERA_ERROR
}

enum ClockPunchAttemptStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum StorageProvider {
  LOCAL
  CLOUDINARY
  GOOGLE_DRIVE
}

enum StorageModule {
  FICHADAS
  LEGAJOS
  NOVEDADES
  TRANSPORTE
  AUDITORIA
  DOCUMENTACION_GENERAL
}

enum StorageEntityType {
  ATTENDANCE_PUNCH
  EMPLOYEE
  EMPLOYEE_DOCUMENT
  ABSENCE
  TRANSPORT
  AUDIT_EVENT
  GENERAL_DOCUMENT
}

enum StorageVisibility {
  PRIVATE
  RRHH_ONLY
  SUPERVISOR_ALLOWED
  SYSTEM_ONLY
}

enum StorageFileStatus {
  ACTIVE
  ARCHIVED
  DELETED
  ERROR
}

enum HourConceptKind {
  NORMAL
  EXTRA
  NOCTURNA
  GUARDIA
  SERENO
  TRANSPORTE
  FERIADO
  OTRO
}

enum DocumentStatus {
  PENDIENTE
  VIGENTE
  POR_VENCER
  VENCIDO
  RECHAZADO
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ACTIVATE
  DEACTIVATE
  APPROVE
  REJECT
  RETURN
  LOGIN
  EXPORT
}

enum MonthlyClosureStatus {
  ABIERTO
  ENVIADO
  APROBADO
  DEVUELTO
  CORRECCION_PENDIENTE
}

enum CorrectionRequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum NotificationStatus {
  NO_LEIDA
  LEIDA
}

enum ShiftAlertType {
  INGRESO_TARDE
  SALIDA_ANTICIPADA
  SALIDA_TARDIA
  TURNO_NO_IDENTIFICADO
  SHIFT_NOT_ENABLED_FOR_EMPLOYEE
  POSSIBLE_SHIFT_CONFIGURATION_MISSING
  JORNADA_INSUFICIENTE
  JORNADA_EXTENDIDA
  DESCANSO_INSUFICIENTE
  POSIBLE_OLVIDO_SALIDA
}

enum ShiftAlertStatus {
  PENDIENTE
  RESUELTA
  DESCARTADA
}

enum ShiftAlertSeverity {
  INFO
  ADVERTENCIA
  CRITICA
}

enum ShiftAssignmentStatus {
  HABILITADO
  DESHABILITADO
}

enum RecurrenceType {
  FECHA
  RANGO
  SEMANAL
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         RoleName
  status       RecordStatus @default(ACTIVO)
  companyId    String?
  sectorId     String?
  employeeId   String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  company             Company?               @relation(fields: [companyId], references: [id])
  sector              Sector?                @relation(fields: [sectorId], references: [id])
  employee            Employee?              @relation("EmployeeUserAccount", fields: [employeeId], references: [id])
  createdEmployees    Employee[]             @relation("EmployeeCreatedBy")
  employeeAssignments EmployeeAssignment[]
  laborMovements      LaborMovement[]
  fieldHistory        EmployeeFieldHistory[]
  blockHistory        EmployeeBlockHistory[]
  noveltiesCreated    Novelty[]              @relation("NoveltyCreatedBy")
  timeEntriesCreated  TimeEntry[]            @relation("TimeEntryCreatedBy")
  documentsUploaded   EmployeeDocument[]
  storageFilesUploaded StorageFile[]          @relation("StorageFileUploadedBy")
  storageFilesDeleted  StorageFile[]          @relation("StorageFileDeletedBy")
  auditLogs           AuditLog[]
  notifications       SystemNotification[] @relation("NotificationRecipient")
  closuresSubmitted   MonthlyTimeClosure[] @relation("ClosureSubmittedBy")
  closuresReviewed    MonthlyTimeClosure[] @relation("ClosureReviewedBy")
  correctionsCreated  TimeCorrectionRequest[] @relation("CorrectionCreatedBy")
  correctionsReviewed TimeCorrectionRequest[] @relation("CorrectionReviewedBy")
  inactivityIncidentsReviewed AttendanceInactivityIncident[] @relation("InactivityIncidentReviewedBy")

  @@index([role])
  @@index([status])
}

model Company {
  id        String       @id @default(uuid())
  name      String       @unique
  code      String       @unique
  status    RecordStatus @default(ACTIVO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users              User[]
  businessUnits      BusinessUnit[]
  establishments     Establishment[]
  employees          EmployeeCompany[]
  businessUnitLinks  BusinessUnitCompany[]
  establishmentLinks EstablishmentCompany[]
  costCenterLinks    CostCenterCompany[]
}

model BusinessUnit {
  id        String       @id @default(uuid())
  name      String
  code      String
  status    RecordStatus @default(ACTIVO)
  companyId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  company            Company                     @relation(fields: [companyId], references: [id])
  establishments     Establishment[]
  companies          BusinessUnitCompany[]
  establishmentLinks EstablishmentBusinessUnit[]
  areaLinks          AreaBusinessUnit[]
  costCenterLinks    CostCenterBusinessUnit[]

  @@unique([companyId, code])
  @@index([companyId])
}

model BusinessUnitCompany {
  businessUnitId String
  companyId      String

  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([businessUnitId, companyId])
  @@index([companyId])
}

model Establishment {
  id             String       @id @default(uuid())
  name           String
  code           String
  status         RecordStatus @default(ACTIVO)
  companyId      String
  businessUnitId String?
  province       String?
  department     String?
  city           String?
  street         String?
  streetNumber   String?
  postalCode     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company         Company                     @relation(fields: [companyId], references: [id])
  businessUnit    BusinessUnit?               @relation(fields: [businessUnitId], references: [id])
  areas           Area[]
  companies       EstablishmentCompany[]
  businessUnits   EstablishmentBusinessUnit[]
  areaLinks       AreaEstablishment[]
  sectorLinks     SectorEstablishment[]
  costCenterLinks CostCenterEstablishment[]

  @@unique([companyId, code])
  @@index([businessUnitId])
}

model EstablishmentCompany {
  establishmentId String
  companyId       String

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([establishmentId, companyId])
  @@index([companyId])
}

model EstablishmentBusinessUnit {
  establishmentId String
  businessUnitId  String

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  businessUnit  BusinessUnit  @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)

  @@id([establishmentId, businessUnitId])
  @@index([businessUnitId])
}

model Area {
  id              String       @id @default(uuid())
  name            String
  code            String       @unique
  status          RecordStatus @default(ACTIVO)
  establishmentId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  establishment   Establishment?      @relation(fields: [establishmentId], references: [id])
  sectors         Sector[]
  positions       Position[]
  businessUnits   AreaBusinessUnit[]
  establishments  AreaEstablishment[]
  sectorLinks     SectorArea[]
  costCenterLinks CostCenterArea[]

  @@index([establishmentId])
}

model AreaBusinessUnit {
  areaId         String
  businessUnitId String

  area         Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)

  @@id([areaId, businessUnitId])
  @@index([businessUnitId])
}

model AreaEstablishment {
  areaId          String
  establishmentId String

  area          Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@id([areaId, establishmentId])
  @@index([establishmentId])
}

model Sector {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVO)
  areaId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  area            Area?                 @relation(fields: [areaId], references: [id])
  users           User[]
  employees       Employee[]
  positions       Position[]
  areas           SectorArea[]
  establishments  SectorEstablishment[]
  costCenterLinks CostCenterSector[]

  @@index([areaId])
}

model SectorArea {
  sectorId String
  areaId   String

  sector Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([sectorId, areaId])
  @@index([areaId])
}

model SectorEstablishment {
  sectorId        String
  establishmentId String

  sector        Sector        @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@id([sectorId, establishmentId])
  @@index([establishmentId])
}

model CostCenter {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  employees      Employee[]
  companies      CostCenterCompany[]
  businessUnits  CostCenterBusinessUnit[]
  establishments CostCenterEstablishment[]
  areas          CostCenterArea[]
  sectors        CostCenterSector[]
}

model CostCenterCompany {
  costCenterId String
  companyId    String

  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([costCenterId, companyId])
  @@index([companyId])
}

model CostCenterBusinessUnit {
  costCenterId   String
  businessUnitId String

  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)

  @@id([costCenterId, businessUnitId])
  @@index([businessUnitId])
}

model CostCenterEstablishment {
  costCenterId    String
  establishmentId String

  costCenter    CostCenter    @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@id([costCenterId, establishmentId])
  @@index([establishmentId])
}

model CostCenterArea {
  costCenterId String
  areaId       String

  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  area       Area       @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([costCenterId, areaId])
  @@index([areaId])
}

model CostCenterSector {
  costCenterId String
  sectorId     String

  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  sector     Sector     @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([costCenterId, sectorId])
  @@index([sectorId])
}

model SalaryCategory {
  id        String       @id @default(uuid())
  name      String       @unique
  family    String?
  order     Int
  status    RecordStatus @default(ACTIVO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  positions PositionSalaryCategory[]

  @@index([status])
}

model Position {
  id                    String       @id @default(uuid())
  code                  String       @unique
  name                  String
  status                RecordStatus @default(ACTIVO)
  mission               String?
  description           String?
  areaDepartment        String?
  sectorName            String?
  businessUnitName      String?
  establishmentName     String?
  lastUpdatedAt         DateTime?
  businessUnitNames     Json?
  establishmentNames    Json?
  sectorNames           Json?
  salaryRangeCategories Json?
  responsibilities      Json?
  internalRelations     Json?
  externalRelations     Json?
  competencies          Json?
  workConditions        Json?
  performanceIndicators Json?
  evaluationCriteria    Json?
  areaId                String?
  sectorId              String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  area             Area?                    @relation(fields: [areaId], references: [id])
  sector           Sector?                  @relation(fields: [sectorId], references: [id])
  employees        Employee[]
  salaryCategories PositionSalaryCategory[]

  @@index([areaId])
  @@index([sectorId])
  @@index([status])
  @@index([areaId, sectorId])
}

model PositionSalaryCategory {
  positionId       String
  salaryCategoryId String

  position       Position       @relation(fields: [positionId], references: [id], onDelete: Cascade)
  salaryCategory SalaryCategory @relation(fields: [salaryCategoryId], references: [id], onDelete: Cascade)

  @@id([positionId, salaryCategoryId])
}

model Employee {
  id                String         @id @default(uuid())
  legajo            String         @unique
  legajoFinnegans   String?
  cuil              String         @unique
  dni               String         @unique
  firstName         String
  lastName          String
  birthDate         DateTime?
  gender            String?
  civilStatus       String?
  nationality       String?
  email             String?
  phone             String?
  mobile            String?
  emergencyContact  String?
  emergencyRelation String?
  emergencyPhone    String?
  status            EmployeeStatus @default(ACTIVO)
  positionId        String?
  sectorId          String?
  costCenterId      String?
  healthInsurance   String?
  agreement         String?
  receiptCategory   String?
  internalCategory  String?
  createdByUserId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  position          Position?              @relation(fields: [positionId], references: [id])
  sector            Sector?                @relation(fields: [sectorId], references: [id])
  costCenter        CostCenter?            @relation(fields: [costCenterId], references: [id])
  createdBy         User?                  @relation("EmployeeCreatedBy", fields: [createdByUserId], references: [id])
  address           EmployeeAddress?
  companies         EmployeeCompany[]
  laborMovements    LaborMovement[]
  assignments       EmployeeAssignment[]
  hourConcepts      EmployeeHourConcept[]
  transport         EmployeeTransport?
  fieldHistory      EmployeeFieldHistory[]
  blockHistory      EmployeeBlockHistory[]
  novelties         Novelty[]
  timeEntries       TimeEntry[]
  workShifts        WorkShift[]
  attendancePunches AttendancePunch[]
  clockPunchAttempts ClockPunchAttempt[]
  timeSegments      TimeSegment[]
  documents         EmployeeDocument[]
  storageFiles      StorageFile[]
  monthlyClosures   MonthlyTimeClosure[]
  correctionRequests TimeCorrectionRequest[]
  shiftAlerts       ShiftAlert[]
  inactivityIncidents AttendanceInactivityIncident[]
  doubleHourAssignments DoubleHourRuleEmployee[]
  shiftAssignments  ShiftAssignment[]
  userAccount       User?                  @relation("EmployeeUserAccount")

  @@index([lastName, firstName])
  @@index([status])
  @@index([status, lastName, firstName])
  @@index([status, sectorId])
  @@index([status, costCenterId])
  @@index([sectorId])
  @@index([costCenterId])
}

model EmployeeCompany {
  employeeId String
  companyId  String
  isPrimary  Boolean @default(false)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([employeeId, companyId])
  @@index([companyId])
  @@index([companyId, employeeId])
}

model EmployeeAddress {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  province     String?
  department   String?
  city         String?
  street       String?
  streetNumber String?
  postalCode   String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  mapLabel     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeTransport {
  id                   String   @id @default(uuid())
  employeeId           String   @unique
  usesCompanyTransport Boolean  @default(false)
  locality             String?
  pickupAddress        String?
  pickupReference      String?
  busLine              String?
  schedule             String?
  observation          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([usesCompanyTransport])
}

model LaborMovement {
  id              String            @id @default(uuid())
  employeeId      String
  type            LaborMovementType
  effectiveFrom   DateTime
  reason          String
  observation     String?
  createdByUserId String?
  createdAt       DateTime          @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdByUserId], references: [id])

  @@index([employeeId, effectiveFrom])
  @@index([employeeId, type])
  @@index([type, effectiveFrom, employeeId])
}

model EmployeeAssignment {
  id            String    @id @default(uuid())
  employeeId    String
  userId        String?
  personName    String?
  type          String
  role          String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  status        String?
  notes         String?
  createdAt     DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([employeeId, type])
  @@index([userId])
}

model HourConcept {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  kind           HourConceptKind
  status         RecordStatus    @default(ACTIVO)
  countsAsWorked Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  employees    EmployeeHourConcept[]
  timeEntries  TimeEntry[]
  novelties    Novelty[]
  timeSegments TimeSegment[]
  workShifts   WorkShift[]

  @@index([status])
}

model EmployeeHourConcept {
  employeeId    String
  hourConceptId String

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hourConcept HourConcept @relation(fields: [hourConceptId], references: [id], onDelete: Cascade)

  @@id([employeeId, hourConceptId])
}

model EmployeeFieldHistory {
  id              String   @id @default(uuid())
  employeeId      String
  section         String
  field           String
  fieldLabel      String
  oldValue        String?
  newValue        String
  effectiveFrom   DateTime
  reason          String
  createdByUserId String?
  createdAt       DateTime @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdByUserId], references: [id])

  @@index([employeeId, section, field])
  @@index([effectiveFrom])
}

model EmployeeBlockHistory {
  id              String   @id @default(uuid())
  employeeId      String
  section         String
  block           String
  blockLabel      String
  oldValue        String?
  newValue        String
  effectiveFrom   DateTime
  reason          String
  createdByUserId String?
  createdAt       DateTime @default(now())

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdByUserId], references: [id])

  @@index([employeeId, section, block])
  @@index([effectiveFrom])
}

model NoveltyType {
  id                    String            @id @default(uuid())
  code                  String            @unique
  name                  String
  uiColor               String
  kind                  NoveltyTypeKind
  origin                NoveltyTypeOrigin
  status                RecordStatus      @default(ACTIVO)
  description           String?
  exportsToFinnegans    Boolean           @default(false)
  requiresApproval      Boolean           @default(true)
  requiresDocumentation Boolean           @default(false)
  allowsHours           Boolean           @default(false)
  allowsDateTo          Boolean           @default(true)
  hasValidity           Boolean           @default(true)
  blocksTimeEntry       Boolean           @default(false)
  setsWorkedHoursToZero Boolean           @default(false)
  timeImpact            NoveltyTimeImpact @default(NO_AFECTA_HORAS)
  allowedLoadRoles      Json              @default("[]")
  approvalRoles         Json              @default("[]")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  finnegansLinks FinnegansNoveltyLink[]
  novelties      Novelty[]

  @@index([status])
}

model FinnegansNoveltyLink {
  id            String       @id @default(uuid())
  noveltyTypeId String
  code          String
  name          String
  exportConcept String
  priority      Int          @default(1)
  status        RecordStatus @default(ACTIVO)
  hasValidity   Boolean      @default(false)
  notes         String?

  noveltyType NoveltyType @relation(fields: [noveltyTypeId], references: [id], onDelete: Cascade)

  @@unique([noveltyTypeId, code])
  @@index([noveltyTypeId])
}

model Novelty {
  id                  String         @id @default(uuid())
  employeeId          String
  noveltyTypeId       String
  status              ApprovalStatus @default(PENDIENTE)
  fromDate            DateTime
  toDate              DateTime?
  quantityHours       Decimal?       @db.Decimal(8, 2)
  quantityDays        Decimal?       @db.Decimal(8, 2)
  observation         String?
  targetHourConceptId String?
  createdByUserId     String?
  approvedByUserId    String?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  employee          Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  noveltyType       NoveltyType        @relation(fields: [noveltyTypeId], references: [id])
  targetHourConcept HourConcept?       @relation(fields: [targetHourConceptId], references: [id])
  createdBy         User?              @relation("NoveltyCreatedBy", fields: [createdByUserId], references: [id])
  documents         EmployeeDocument[]

  @@index([employeeId, fromDate])
  @@index([employeeId, status, fromDate])
  @@index([status, fromDate])
  @@index([fromDate, toDate])
  @@index([noveltyTypeId])
  @@index([status])
}

model TimeEntry {
  id               String           @id @default(uuid())
  employeeId       String
  hourConceptId    String
  workShiftId      String?
  timeSegmentId    String?
  date             DateTime
  period           String
  day              Int
  hours            Decimal          @db.Decimal(8, 2)
  totalMinutes     Int
  actualMinutes    Int?
  appliedMultiplier Decimal        @default(1) @db.Decimal(4, 2)
  segmentStartAt   DateTime?
  segmentEndAt     DateTime?
  source           WorkShiftSource?
  status           ApprovalStatus   @default(BORRADOR)
  observation      String?
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hourConcept HourConcept  @relation(fields: [hourConceptId], references: [id])
  workShift   WorkShift?   @relation(fields: [workShiftId], references: [id], onDelete: SetNull)
  timeSegment TimeSegment? @relation(fields: [timeSegmentId], references: [id], onDelete: SetNull)
  createdBy   User?        @relation("TimeEntryCreatedBy", fields: [createdByUserId], references: [id])
  correctionRequests TimeCorrectionRequest[]

  @@index([employeeId, period])
  @@index([employeeId, hourConceptId, date])
  @@index([workShiftId])
  @@index([timeSegmentId])
  @@index([period, employeeId])
  @@index([period, status])
  @@index([period, status, employeeId])
  @@index([period, status, date, createdAt])
  @@index([date])
  @@index([status])
  @@index([status, period])
}

model WorkShift {
  id                String          @id @default(uuid())
  employeeId        String
  hourConceptId     String?
  hourConceptName   String?
  startPunchId      String?
  endPunchId        String?
  source            WorkShiftSource @default(ADMIN)
  status            WorkShiftStatus @default(PROCESADO)
  startAt           DateTime
  endAt             DateTime?
  totalMinutes      Int?
  crossesMidnight   Boolean         @default(false)
  maxAllowedMinutes Int             @default(1200)
  observation       String?
  reviewStatus      AttendanceReviewStatus @default(PENDIENTE)
  reviewedAt        DateTime?
  reviewedByUserId  String?
  reviewNote        String?
  shiftTemplateId   String?
  createdByUserId   String?
  createdAt         DateTime        @default(now())
  closedAt          DateTime?
  updatedAt         DateTime        @updatedAt

  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hourConcept  HourConcept?     @relation(fields: [hourConceptId], references: [id], onDelete: SetNull)
  startPunch   AttendancePunch? @relation("WorkShiftStartPunch", fields: [startPunchId], references: [id], onDelete: SetNull)
  endPunch     AttendancePunch? @relation("WorkShiftEndPunch", fields: [endPunchId], references: [id], onDelete: SetNull)
  timeEntries  TimeEntry[]
  timeSegments TimeSegment[]
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  shiftAlerts ShiftAlert[]

  @@index([employeeId, startAt])
  @@index([hourConceptId])
  @@index([employeeId, endAt])
  @@index([status, startAt])
  @@index([startAt, endAt])
  @@index([startPunchId])
  @@index([endPunchId])
  @@index([status])
  @@index([reviewStatus, startAt])
  @@index([source])
  @@index([shiftTemplateId])
}

model MonthlyTimeClosure {
  id String @id @default(uuid())
  employeeId String
  period String
  status MonthlyClosureStatus @default(ABIERTO)
  snapshot Json?
  submittedByUserId String?
  submittedAt DateTime?
  reviewedByUserId String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  submittedBy User? @relation("ClosureSubmittedBy", fields: [submittedByUserId], references: [id])
  reviewedBy User? @relation("ClosureReviewedBy", fields: [reviewedByUserId], references: [id])
  corrections TimeCorrectionRequest[]
  @@unique([employeeId, period])
  @@index([period, status])
}

model TimeCorrectionRequest {
  id String @id @default(uuid())
  employeeId String
  timeEntryId String
  closureId String?
  previousHours Decimal @db.Decimal(8, 2)
  proposedHours Decimal @db.Decimal(8, 2)
  reason String
  status CorrectionRequestStatus @default(PENDIENTE)
  createdByUserId String
  reviewedByUserId String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt DateTime @default(now())
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  timeEntry TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  closure MonthlyTimeClosure? @relation(fields: [closureId], references: [id], onDelete: SetNull)
  createdBy User @relation("CorrectionCreatedBy", fields: [createdByUserId], references: [id])
  reviewedBy User? @relation("CorrectionReviewedBy", fields: [reviewedByUserId], references: [id])
  @@index([status, createdAt])
  @@index([employeeId, status])
}

model SystemNotification {
  id String @id @default(uuid())
  recipientUserId String
  type String
  priority String @default("NORMAL")
  title String
  message String
  entityType String?
  entityId String?
  link String?
  status NotificationStatus @default(NO_LEIDA)
  readAt DateTime?
  createdAt DateTime @default(now())
  recipient User @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  @@index([recipientUserId, status, createdAt])
}

model ShiftTemplate {
  id String @id @default(uuid())
  code String @unique
  name String
  description String?
  categoryName String?
  startTime String
  endTime String
  crossesMidnight Boolean @default(false)
  expectedMinutes Int?
  entryToleranceBeforeMinutes Int @default(10)
  entryToleranceAfterMinutes Int @default(10)
  exitToleranceBeforeMinutes Int @default(20)
  exitToleranceAfterMinutes Int @default(20)
  minimumMinutesForCompliance Int?
  maximumInformativeMinutes Int?
  missingOutAlertAfterMinutes Int?
  absoluteOpenShiftLimitMinutes Int @default(1200)
  status RecordStatus @default(ACTIVO)
  createdByUserId String?
  updatedByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  workShifts WorkShift[]
  assignments ShiftAssignment[]
  @@index([status])
  @@index([categoryName])
}

model ShiftAssignment {
  id               String                @id @default(uuid())
  employeeId       String
  shiftTemplateId  String
  status           ShiftAssignmentStatus @default(HABILITADO)
  assignedAt       DateTime              @default(now())
  assignedByUserId String?
  disabledAt       DateTime?
  disabledByUserId String?
  observation      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftTemplateId])
  @@index([employeeId, status])
  @@index([shiftTemplateId, status])
}

model ShiftAlert {
  id String @id @default(uuid())
  employeeId String
  workShiftId String
  type ShiftAlertType
  status ShiftAlertStatus @default(PENDIENTE)
  severity ShiftAlertSeverity @default(INFO)
  scheduledAt DateTime?
  actualAt DateTime
  differenceMinutes Int?
  resolvedAt DateTime?
  resolvedByUserId String?
  resolutionNote String?
  createdAt DateTime @default(now())
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workShift WorkShift @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  @@unique([workShiftId, type])
  @@index([employeeId, status, createdAt])
  @@index([severity, status])
}

model AttendanceInactivityIncident {
  id               String                 @id @default(uuid())
  employeeId       String
  operationalDate  DateTime               @db.Date
  status           AttendanceReviewStatus @default(PENDIENTE)
  observation      String
  detectedAt       DateTime               @default(now())
  notifiedAt       DateTime?
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewNote       String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("InactivityIncidentReviewedBy", fields: [reviewedByUserId], references: [id])

  @@unique([employeeId, operationalDate])
  @@index([status, operationalDate])
  @@index([employeeId, status])
}

model DoubleHourRule {
  id String @id @default(uuid())
  name String
  recurrenceType RecurrenceType
  fromDate DateTime
  toDate DateTime?
  weekdays Int[] @default([])
  multiplier Decimal @default(2) @db.Decimal(4, 2)
  status RecordStatus @default(ACTIVO)
  reason String
  createdByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employees DoubleHourRuleEmployee[]
  @@index([status, fromDate, toDate])
}

model DoubleHourRuleEmployee {
  ruleId String
  employeeId String
  rule DoubleHourRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@id([ruleId, employeeId])
  @@index([employeeId])
}

model AttendancePunch {
  id                String                @id @default(uuid())
  employeeId        String
  type              AttendancePunchType
  timestamp         DateTime
  source            WorkShiftSource       @default(PORTAL_DNI)
  deviceId          String?
  kioskId           String?
  ipAddress         String?
  userAgent         String?
  status            AttendancePunchStatus @default(VALIDA)
  observation       String?
  reviewStatus      AttendanceReviewStatus @default(PENDIENTE)
  reviewedAt        DateTime?
  reviewedByUserId  String?
  reviewNote        String?
  photoUrl          String?
  photoStoragePath  String?
  photoFileId       String?
  thumbnailFileId   String?
  faceDetected      Boolean               @default(false)
  faceValidationStatus FaceValidationStatus?
  faceDetectionScore Float?
  externalPunchId   String?
  rawPayload        Json?
  biometricProvider String?
  importedAt        DateTime?
  createdAt         DateTime              @default(now())

  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  photoFile       StorageFile? @relation("AttendancePunchPhotoFile", fields: [photoFileId], references: [id], onDelete: SetNull)
  thumbnailFile   StorageFile? @relation("AttendancePunchThumbnailFile", fields: [thumbnailFileId], references: [id], onDelete: SetNull)
  startWorkShifts WorkShift[]  @relation("WorkShiftStartPunch")
  endWorkShifts   WorkShift[]  @relation("WorkShiftEndPunch")

  @@index([employeeId, timestamp])
  @@index([status, timestamp])
  @@index([reviewStatus, timestamp])
  @@index([type, status])
  @@index([source])
  @@index([externalPunchId])
  @@index([photoFileId])
  @@index([thumbnailFileId])
}

model ClockPunchAttempt {
  id             String                  @id @default(uuid())
  requestId      String                  @unique
  employeeId     String
  punchType      AttendancePunchType
  status         ClockPunchAttemptStatus @default(PROCESSING)
  requestHash    String
  response       Json?
  errorCode      String?
  errorMessage   String?
  httpStatus     Int?
  startedAt      DateTime                @default(now())
  completedAt    DateTime?
  updatedAt      DateTime                @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, startedAt])
  @@index([status, startedAt])
}

model TimeSegment {
  id              String   @id @default(uuid())
  workShiftId     String
  employeeId      String
  date            DateTime
  fromDateTime    DateTime
  toDateTime      DateTime
  minutes         Int
  hourConceptId   String
  hourConceptName String
  isHoliday       Boolean  @default(false)
  isNight         Boolean  @default(false)
  isSpecial       Boolean  @default(false)
  source          String   @default("CALCULATED")
  observation     String?
  createdAt       DateTime @default(now())

  workShift   WorkShift   @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hourConcept HourConcept @relation(fields: [hourConceptId], references: [id])
  timeEntries TimeEntry[]

  @@index([workShiftId])
  @@index([employeeId, date])
  @@index([hourConceptId])
}

model DocumentCategory {
  id            String       @id @default(uuid())
  code          String       @unique
  name          String
  kind          String       @default("PERSONAL")
  status        RecordStatus @default(ACTIVO)
  description   String?
  scopes        Json         @default("[]")
  rules         Json         @default("{}")
  uploadRoles   Json         @default("[]")
  viewRoles     Json         @default("[]")
  approvalRoles Json         @default("[]")
  externalLinks Json         @default("[]")
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  documents EmployeeDocument[]

  @@index([status])
}

model AuditParameter {
  id                      String       @id @default(uuid())
  code                    String       @unique
  name                    String
  scope                   String
  severity                String
  status                  RecordStatus @default(ACTIVO)
  description             String
  trackCreate             Boolean      @default(true)
  trackUpdate             Boolean      @default(true)
  trackDeleteOrDeactivate Boolean      @default(false)
  trackApproval           Boolean      @default(false)
  trackExport             Boolean      @default(false)
  requiresReason          Boolean      @default(false)
  requiresEffectiveDate   Boolean      @default(false)
  visibleToRoles          Json         @default("[]")
  notification            Json         @default("{}")
  retention               Json         @default("{}")
  notes                   String?
  createdBy               String?
  updatedBy               String?
  history                 Json         @default("[]")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@index([scope])
  @@index([severity])
  @@index([status])
}

model EmployeeDocument {
  id               String         @id @default(uuid())
  employeeId       String
  categoryId       String
  noveltyId        String?
  fileName         String
  fileMimeType     String
  fileSizeBytes    Int
  storageKey       String
  storageFileId    String?
  status           DocumentStatus @default(PENDIENTE)
  notes            String?
  issuedAt         DateTime?
  expiresAt        DateTime?
  uploadedByUserId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category   DocumentCategory @relation(fields: [categoryId], references: [id])
  novelty    Novelty?         @relation(fields: [noveltyId], references: [id])
  uploadedBy User?            @relation(fields: [uploadedByUserId], references: [id])
  storageFile StorageFile?     @relation("EmployeeDocumentStorageFile", fields: [storageFileId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([employeeId, createdAt])
  @@index([categoryId])
  @@index([status])
  @@index([status, expiresAt])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([storageFileId])
}

model StorageFile {
  id                  String            @id @default(uuid())
  storageProvider     StorageProvider
  storageKey          String
  driveFileId         String?
  driveFolderId       String?
  driveWebViewLink    String?
  driveWebContentLink String?
  fileName            String
  originalFileName    String
  mimeType            String
  extension           String
  sizeBytes           Int
  module              StorageModule
  entityType          StorageEntityType
  entityId            String
  employeeId          String?
  attendancePunchId   String?
  documentType        String?
  isThumbnail         Boolean           @default(false)
  thumbnailFileId     String?
  originalFileId      String?
  visibility          StorageVisibility  @default(PRIVATE)
  status              StorageFileStatus  @default(ACTIVE)
  uploadedByUserId    String?
  uploadedAt          DateTime           @default(now())
  deletedByUserId     String?
  deletedAt           DateTime?
  checksum            String?
  metadata            Json               @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  employee            Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  uploadedBy          User?              @relation("StorageFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  deletedBy           User?              @relation("StorageFileDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  employeeDocuments   EmployeeDocument[] @relation("EmployeeDocumentStorageFile")
  attendancePunchPhotoLinks AttendancePunch[] @relation("AttendancePunchPhotoFile")
  attendancePunchThumbnailLinks AttendancePunch[] @relation("AttendancePunchThumbnailFile")

  @@index([storageProvider])
  @@index([storageKey])
  @@index([driveFileId])
  @@index([module, entityType, entityId])
  @@index([employeeId, module])
  @@index([attendancePunchId])
  @@index([status, uploadedAt])
}

model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  entity      String
  entityId    String?
  description String
  before      Json?
  after       Json?
  userId      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([entity, entityId, createdAt])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}
